# 界面主题：light（浅色）或 dark（深色）。
ARCH_AGENT_THEME=light

# Hy3 主 API Key，用于文本分析、对话和通用能力调用。
HY3_API_KEY=
# Hy3 OpenAI-compatible 接口地址。
HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
# 默认 Chat 模型名称。
HY3_CHAT_MODEL=hy3-preview
# Hy3 MCP 与分析产物输出目录。
HY3_OUTPUT_DIR=./data/output/hy3
# 是否允许 Chat 模型直接接收图片输入。
HY3_CHAT_IMAGE_INPUT_ENABLED=false
# 是否启用模型思考模式。
HY3_THINKING_ENABLED=false
# 推理强度参数，留空表示使用模型默认值。
HY3_REASONING_EFFORT=
# 主 Chat 请求超时时间，单位毫秒。
HY3_REQUEST_TIMEOUT_MS=120000
# 上下文窗口大小，单位 token。
HY3_CONTEXT_WINDOW_TOKENS=256000
# 最大输出 token 数。
HY3_MAX_OUTPUT_TOKENS=16000

# 生图接口地址。
HY3_IMAGE_BASE_URL=
# 识图接口地址。
HY3_VISION_BASE_URL=
# 生图 API Key。
HY3_IMAGE_API_KEY=
# 识图 API Key。
HY3_VISION_API_KEY=
# 生图模型名称。
HY3_IMAGE_MODEL=
# 识图模型名称。
HY3_VISION_MODEL=
# 生图尺寸。
HY3_IMAGE_SIZE=1536x1024
# 生图质量等级。
HY3_IMAGE_QUALITY=high
# 是否允许自动生成分析图表和可视化说明图。
HY3_AUTO_IMAGE_GENERATION=false
# 生图请求超时时间，单位毫秒。
HY3_IMAGE_REQUEST_TIMEOUT_MS=300000

# 是否允许 Agent 执行本地 bash / shell 命令。
AGENT_EXEC_BASH_ENABLED=true
# 是否在报告生成后自动导出 PDF。
AGENT_AUTO_PDF_EXPORT=false
# LibreOffice 可执行文件路径，留空则自动查找。
LIBREOFFICE_PATH=
