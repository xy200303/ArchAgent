# ArchAgent 环境配置示例
# 复制为 .env.local 后填写密钥；.env.local 优先于 .env，切勿提交真实密钥。

# -----------------------------------------------------------------------------
# 基础与对话（必填）
# -----------------------------------------------------------------------------
ARCH_AGENT_THEME=light

# 腾讯混元 / OpenAI-compatible 主接口。HY3_* 是推荐名称，程序兼容 OPENAI_* 旧名称。
HY3_API_KEY=
HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
HY3_CHAT_MODEL=hy3-preview

# 是否将上传图片直接附带给对话模型；空间识别仍可使用下方独立视觉模型。
HY3_CHAT_IMAGE_INPUT_ENABLED=false
HY3_THINKING_ENABLED=false
# 可选：minimal、low、medium、high、xhigh；留空使用服务端默认值。
HY3_REASONING_EFFORT=
# 对话请求超时，单位秒。
HY3_REQUEST_TIMEOUT_S=120
HY3_CONTEXT_WINDOW_TOKENS=256000
HY3_MAX_OUTPUT_TOKENS=16000

# -----------------------------------------------------------------------------
# 视觉分析（analyze_reference）
# -----------------------------------------------------------------------------
# 留空时复用 HY3_BASE_URL、HY3_API_KEY 和 HY3_CHAT_MODEL。
HY3_VISION_BASE_URL=
HY3_VISION_API_KEY=
HY3_VISION_MODEL=
# 视觉识别请求超时，单位秒；留空时复用 HY3_REQUEST_TIMEOUT_S。
HY3_VISION_REQUEST_TIMEOUT_S=120

# -----------------------------------------------------------------------------
# 混元生图 3.0（preview_design / isolate_reference_object）
# -----------------------------------------------------------------------------
# 腾讯云原生 SDK：需具备 aiart:SubmitTextToImageJob 与 aiart:QueryTextToImageJob 权限。
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
HY3_IMAGE_REGION=ap-guangzhou
# 宽:高；宽高均 512-2048，总像素不超过 1024:1024。
HY3_IMAGE_RESOLUTION=1024:1024
# 提示词改写约增加 20 秒；AI 标识默认开启。
HY3_IMAGE_REVISE=true
HY3_IMAGE_LOGO_ADD=true
# SDK 单次请求超时、任务轮询间隔和任务最长等待时间，单位秒。
HY3_IMAGE_REQUEST_TIMEOUT_S=300
HY3_IMAGE_POLL_INTERVAL_S=3
HY3_IMAGE_JOB_TIMEOUT_S=900

# -----------------------------------------------------------------------------
# 腾讯混元 3D（确认后的重建工作流）
# -----------------------------------------------------------------------------
# 腾讯云原生 SDK 使用 ai3d:SubmitHunyuanTo3DProJob / ai3d:QueryHunyuanTo3DProJob。
HY3_3D_REGION=ap-guangzhou
# 3.0 支持 LowPoly；3.1 不支持 LowPoly。
HY3_3D_MODEL_VERSION=3.0
# 默认重建使用 LowPoly；此面数仅用于显式普通细节生成，范围 3000-1500000。
HY3_3D_FACE_COUNT=50000
# 生3D提交/查询请求超时、轮询间隔和单任务最大等待时间，单位秒。
HY3_3D_SUBMIT_TIMEOUT_S=120
HY3_3D_POLL_INTERVAL_S=3
HY3_3D_JOB_TIMEOUT_S=900

# -----------------------------------------------------------------------------
# 高级执行与导出（默认安全关闭）
# -----------------------------------------------------------------------------
# 启用后才向 Agent 暴露 exec_external_script；脚本仍须声明用途和预期产物。
AGENT_EXEC_BASH_ENABLED=false
# exec_external_script 的最长执行时间，单位秒。
AGENT_SCRIPT_TIMEOUT_S=60
AGENT_AUTO_PDF_EXPORT=false
# Windows 上 LibreOffice 的可执行文件路径；自动 PDF 导出时才需要。
LIBREOFFICE_PATH=
