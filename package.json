{
  "name": "arch-agent",
  "version": "0.2.1",
  "description": "Desktop spatial design agent powered by Tencent Hunyuan Hy3",
  "author": "xy200303",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "icon:generate": "node scripts/run-generate-app-icon.mjs",
    "build": "tsc --noEmit && electron-vite build",
    "pack": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false CSC_FOR_PULL_REQUEST=false electron-builder --dir",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false CSC_FOR_PULL_REQUEST=false electron-builder",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.xiaoyun.archagent",
    "productName": "ArchAgent",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!out/**/*.log",
      "package.json"
    ],
    "asarUnpack": [
      "out/renderer/assets/*worker*"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build",
        "to": "build",
        "filter": [
          "icon.png",
          "icon.ico"
        ]
      },
      {
        "from": ".env.example",
        "to": ".env"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signtoolOptions": {
        "sign": "./scripts/sign-win-skip-runtime.cjs"
      },
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.10",
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@incremark/core": "^1.0.2",
    "@incremark/react": "^1.0.2",
    "@incremark/theme": "^1.0.2",
    "@jscad/modeling": "^2.13.0",
    "@jscad/obj-serializer": "^2.1.23",
    "@jscad/stl-serializer": "^2.1.23",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@types/three": "^0.185.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.25.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "replicad": "^0.23.1",
    "replicad-opencascadejs": "^0.23.0",
    "sharp": "^0.35.3",
    "three": "^0.185.1",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@electron/asar": "^4.2.0",
    "@electron/get": "^5.0.0"
  }
}
